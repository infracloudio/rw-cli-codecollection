<com.nirima.jenkins.plugins.docker.DockerCloud plugin="docker-plugin">
    <name>docker</name>
    <serverUrl>unix:///var/run/docker.sock</serverUrl>
    <dockerApiVersion></dockerApiVersion>
    <credentialsId></credentialsId>
    <containerCap>10</containerCap>
    <connectTimeout>60</connectTimeout>
    <readTimeout>60</readTimeout>
    <templates>
        <com.nirima.jenkins.plugins.docker.DockerTemplate>
            <labelString>docker-agent</labelString>
            <dockerTemplateBase>
                <image>python:3.10</image>
                <bindAllPorts>false</bindAllPorts>
                <privileged>false</privileged>
                <tty>true</tty>
                <extraHosts></extraHosts>
                <volumes></volumes>
                <environment></environment>
                <hostname></hostname>
                <user></user>
                <dnsHosts></dnsHosts>
                <network></network>
                <memoryLimit>0</memoryLimit>
                <memorySwap>0</memorySwap>
                <cpuShares>0</cpuShares>
                <bindPorts></bindPorts>
                <capabilities></capabilities>
            </dockerTemplateBase>
            <remoteFs>/home/jenkins/agent</remoteFs>
            <instanceCap>5</instanceCap>
        </com.nirima.jenkins.plugins.docker.DockerTemplate>
    </templates>
</com.nirima.jenkins.plugins.docker.DockerCloud>
